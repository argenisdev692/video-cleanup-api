APP_NAME=video-cleanup-api
APP_ENV=local
APP_KEY=base64:your-app-key-here
APP_DEBUG=true
APP_PORT=8080
APP_URL=http://localhost:8080


R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_DEFAULT_REGION=auto
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_BASE_URL=https://your-r2-endpoint.r2.cloudflarestorage.com
R2_ENDPOINT=https://your-r2-endpoint.r2.cloudflarestorage.com
R2_URL=https://your-r2-endpoint.r2.cloudflarestorage.com
R2_USE_PATH_STYLE_ENDPOINT=false


# Tutorial Cleanup Storage / FastAPI
TUTORIAL_CLEANUP_API_BASE_URL=http://127.0.0.1:8001

TUTORIAL_CLEANUP_TIMEOUT_SECONDS=300
TUTORIAL_CLEANUP_ANALYSIS_MODEL=faster-whisper+llm
TUTORIAL_CLEANUP_STORAGE_DISK=r2
TUTORIAL_CLEANUP_STORAGE_DIRECTORY=ai/tutorial-cleanups
TUTORIAL_CLEANUP_REMOTION_RENDER_DIRECTORY=renders/tutorial-cleanup

TUTORIAL_CLEANUP_API_TOKEN=your-api-token-here
TUTORIAL_CLEANUP_ARTIFACT_ROOT=/data/artifacts
TUTORIAL_CLEANUP_ALLOW_REMOTE_DOWNLOADS=true
TUTORIAL_CLEANUP_DOWNLOAD_TIMEOUT_SECONDS=120
TUTORIAL_CLEANUP_LOCAL_INPUT_ROOTS=
TUTORIAL_CLEANUP_PATH_MAP_FROM=
TUTORIAL_CLEANUP_PATH_MAP_TO=
TUTORIAL_CLEANUP_REMOTION_COMPOSITION_ID=TutorialCapcutClean
TUTORIAL_CLEANUP_REMOTION_FPS=30
TUTORIAL_CLEANUP_REMOTION_WIDTH=1920
TUTORIAL_CLEANUP_REMOTION_HEIGHT=1080

# Audio Processing Configuration
TUTORIAL_CLEANUP_CLEAN_TARGET_LUFS=-14.0
TUTORIAL_CLEANUP_CLEAN_AFFTDN_NF=-30
TUTORIAL_CLEANUP_CLEAN_HIGHPASS_HZ=80
TUTORIAL_CLEANUP_CLEAN_LOWPASS_HZ=12000

# Cloudflare R2 Storage Configuration
TUTORIAL_CLEANUP_R2_ACCOUNT_ID=
TUTORIAL_CLEANUP_R2_ACCESS_KEY_ID=
TUTORIAL_CLEANUP_R2_SECRET_ACCESS_KEY=
TUTORIAL_CLEANUP_R2_BUCKET_NAME=
TUTORIAL_CLEANUP_R2_ENDPOINT=https://
TUTORIAL_CLEANUP_R2_PUBLIC_BASE_URL=https://


